PORT=app_port
HOST=0.0.0.0

AMO_CLIENT_RETRY_ATTEMPTS=3
AMO_CLIENT_BASE_DELAY_MS=200
AMO_CLIENT_RPS=7

AMO_OAUTH_URL=https://www.amocrm.ru/oauth
AMO_CLIENT_ID=amo_integration_uuid
AMO_CLIENT_SECRET=amo_integration_secret
# Тот же URL, что Redirect URI в настройках интеграции amoCRM (не google.com)
AMO_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/complete
API_PUBLIC_URL=http://localhost:8080

# CORS для запросов с фронта (через запятую, если несколько origin)
FRONTEND_ORIGIN=http://localhost:5173
# Порт vite preview на сервере (scripts/deploy-frontend.sh)
FRONTEND_PORT=4173

SERVER_API_KEY=server_api_key

# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# DATABASE_URL нужен только для ЛОКАЛЬНОГО запуска (без docker) и для prisma CLI.
# В docker этот параметр перекрывается в docker-compose*.yml: там DATABASE_URL
# собирается из POSTGRES_* (docker/.env) и указывает на сервис postgres:5432.
DATABASE_URL="postgresql://postgres:password@localhost:5432/neuro_okk_amo?sslmode=disable"