# Переменные для docker compose (интерполяция ${...} в docker-compose*.yml).
# Compose подхватывает этот файл автоматически, если запускать из папки docker/:
#   cd docker && docker compose up -d            (или -f docker-compose.dev.yml)
# Имя БД и креды postgres задаются ТОЛЬКО здесь — app собирает из них DATABASE_URL,
# поэтому строку подключения отдельно прописывать не нужно.

APP_PORT=app_port

POSTGRES_PORT=postgres_port
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres_db_name
